run = "python app.py"
entrypoint = "app.py"
modules = ["python-3.11"]

[deployment]
run = ["sh", "-c", "gunicorn app:app --bind 0.0.0.0:$PORT"]

[nix]
channel = "stable-25_05"
packages = ["freetype", "glibcLocales", "gumbo", "harfbuzz", "jbig2dec", "lcms2", "libimagequant", "libjpeg", "libjpeg_turbo", "libtiff", "libwebp", "libxcrypt", "mupdf", "openjpeg", "swig", "tcl", "tk", "xcbuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "DATABASE_URL='sqlite:///tpq_hmarisa.db' python app.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
