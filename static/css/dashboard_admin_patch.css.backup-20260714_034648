/* Patch Dasbor Admin V1 — logo konsisten, kartu hijau, silabus, dan pengguna. */
.brand-logo-final{
  width:76px!important;height:76px!important;padding:2px!important;
  border-radius:18px!important;overflow:hidden;background:#fff;
}
.brand-logo-final img,.brand-logo img,.mobile-brand img{
  object-fit:contain!important;object-position:center!important;
}
.brand-logo-final img{transform:scale(1.02)!important;border-radius:13px!important}
.mobile-brand img{padding:2px!important;transform:none!important}
.drawer-head .brand-logo{padding:2px!important}
.drawer-head .brand-logo img{transform:scale(1.02)!important}

.dashboard-green-pair{align-items:stretch}
.dashboard-green-card{
  color:#fff!important;
  background:linear-gradient(145deg,#064e3b 0%,#075f46 55%,#0b7b5a 100%)!important;
  border:1px solid rgba(229,169,59,.42)!important;
  box-shadow:0 20px 45px rgba(6,78,59,.17)!important;
  overflow:hidden;position:relative;
}
.dashboard-green-card:after{
  content:"";position:absolute;width:220px;height:220px;border-radius:50%;
  right:-95px;bottom:-115px;background:rgba(255,255,255,.045);pointer-events:none;
}
.dashboard-green-card .card-head{border-color:rgba(255,255,255,.16)!important;position:relative;z-index:1}
.dashboard-green-card .card-head h2,
.dashboard-green-card .card-head a,
.dashboard-green-card .hadith-translation,
.dashboard-green-card .dashboard-arabic{color:#fff!important}
.dashboard-green-card .card-head a{background:rgba(255,255,255,.12);padding:7px 11px;border-radius:999px}
.dashboard-green-card small,.dashboard-green-card .muted{color:rgba(255,255,255,.78)!important}
.dashboard-green-card .dashboard-arabic{font-size:30px!important;margin:15px 0 5px}
.dashboard-green-card .hadith-translation{font-size:16px!important}
.green-soft-label{background:rgba(255,255,255,.14);color:#d1fae5;padding:6px 10px;border-radius:999px;font-size:10px;font-weight:800}
.green-empty{color:rgba(255,255,255,.82)!important}
.dashboard-green-card .winner-dashboard-list article{background:rgba(255,255,255,.09)!important;border-color:rgba(255,255,255,.14)!important;position:relative;z-index:1}
.dashboard-green-card .winner-dashboard-list article strong{color:#fff!important}
.dashboard-green-card .winner-dashboard-list article p{color:rgba(255,255,255,.74)!important}
.dashboard-green-card .winner-icon{background:#f4c454!important;color:#064e3b!important}
.dashboard-green-card .score-badge{background:#f4c454!important;color:#064e3b!important}

#dashboard-syllabus{scroll-margin-top:110px}
.dashboard-syllabus-form{align-items:end}
.dashboard-syllabus-form .btn{min-height:46px}

.user-management-grid{align-items:start}
.divider-label{font-size:11px;font-weight:800;color:#075f46;border-top:1px solid #e2e8f0;padding-top:13px;margin-top:3px}
.user-account-list{display:grid;gap:14px}
.user-account-card{border:1px solid #dce7e2;border-radius:17px;padding:16px;background:#fff}
.user-account-card.account-disabled{background:#f8faf9;opacity:.78}
.user-account-summary{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:13px}
.user-account-summary small,.user-account-summary span{display:block;color:#718078;font-size:10px;margin-top:4px}
.user-account-summary>.badge{margin:0;color:#075f46}
.account-edit-details{margin-top:13px;border-top:1px solid #edf2ef;padding-top:12px}
.account-edit-details>summary{cursor:pointer;color:#075f46;font-weight:800;list-style:none}
.account-edit-details>summary::-webkit-details-marker{display:none}
.account-edit-details form{margin-top:13px}
.inline-toggle-form{margin-top:12px}
.superadmin-note{margin:13px 0 0;padding:10px 12px;border-radius:11px;background:#edf7f2;color:#075f46;font-size:10.5px}

@media(max-width:820px){
  .brand-logo-final{width:58px!important;height:58px!important;border-radius:15px!important}
  .mobile-brand img{width:50px!important;height:50px!important;border-radius:14px!important}
  .user-account-summary{grid-template-columns:auto 1fr}.user-account-summary>.badge{grid-column:2}
}
@media(max-width:620px){
  .dashboard-green-card .dashboard-arabic{font-size:25px!important}
  .user-account-summary{grid-template-columns:1fr;text-align:left}.user-account-summary .user-avatar{display:none}.user-account-summary>.badge{grid-column:auto;justify-self:start}
}
